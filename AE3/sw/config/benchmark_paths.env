#!/usr/bin/env bash

# These workloads are intentionally not distributed with the artifact.
# Keep these as absolute paths on SPR1, or edit them for another machine.
SPEC_ROOT="${SPEC_ROOT:-/research/chihun/bench/spec2017}"
SPEC_RUNCPU="${SPEC_RUNCPU:-${SPEC_ROOT}/bin/runcpu}"
SPEC_CONFIG="${SPEC_CONFIG:-${SPEC_ROOT}/config/myprogram-gcc-linux-x86.cfg}"

GAPBS_ROOT="${GAPBS_ROOT:-/research/chihuns2/bench/gapbs/gapbs}"
GAPBS_GRAPH_DIR="${GAPBS_GRAPH_DIR:-${GAPBS_ROOT}/benchmark/graphs}"
GAPBS_WEB_GRAPH="${GAPBS_WEB_GRAPH:-}"
GAPBS_TWITTER_GRAPH="${GAPBS_TWITTER_GRAPH:-}"

# Required only for the DAMON comparison mode.  DAMO and its migration-policy
# JSON are already installed/configured on SPR1 and are not copied into AE3.
# Reference implementation:
# https://github.com/ece-fast-lab/ASPLOS-2025-M5/tree/main/sw/damo
#
# The defaults below are the existing shared SPR1 installation and the exact
# migrate_cold-to-Node-1 / migrate_hot-to-Node-0 policy used by the legacy
# Figure 3 scripts.  Export either variable before running to override it.
DAMO_BIN="${DAMO_BIN:-/fast-lab-share/chihuns2/CHMU/chmu_man/damo/tools/damo/damo}"
if [[ "$DAMO_BIN" != */* ]]; then
    DAMO_BIN="$(command -v -- "$DAMO_BIN" 2>/dev/null || printf '%s' "$DAMO_BIN")"
fi
DAMO_CONFIG="${DAMO_CONFIG:-/fast-lab-share/chihuns2/CHMU/chmu_man/damo/tools/damo/output.json}"
export DAMO_BIN DAMO_CONFIG

# Override when the custom-kernel perf tool is required.
CHMU_PERF_BIN="${CHMU_PERF_BIN:-/usr/bin/perf}"
