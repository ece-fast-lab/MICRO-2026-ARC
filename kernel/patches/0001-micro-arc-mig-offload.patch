+/**
+ * ****************************
+ * Memory Allocation Functions
+ * ****************************
+*/
+static unsigned long allocate_tracer_region(int nid, int page_cnt, uint64_t* pa_ret, uint32_t** va_ptr_ret) {
+	pr_info("tracer alloc size 0x%lx\n", page_cnt * PAGE_SIZE);
+    if (page_cnt <= 0) return 0;
+
+    if (nid >= num_online_nodes()) return 0;
+
+	//unsigned long page_cnt = ALIGN(TRACER_REGION_SIZE, PAGE_SIZE) / PAGE_SIZE;
+	struct page *head = NULL;
+	head = alloc_contig_pages(page_cnt, GFP_KERNEL | __GFP_ZERO, nid, NULL);
+
+	if (!head)
+		return 0;
+
+	*pa_ret = PFN_PHYS(page_to_pfn(head));
+	pr_info("tracer alloc %d pages at %llx\n", page_cnt, *pa_ret);
+
+    *va_ptr_ret = page_to_virt(head);
+
+	return *pa_ret;
+}
+
+static void free_tracer_region(unsigned long pa, int page_cnt)
+{
+	//unsigned long page_cnt = ALIGN(TRACER_REGION_SIZE, PAGE_SIZE) / PAGE_SIZE;
+	pr_info("tracer free %d pages at 0x%lx\n", page_cnt, pa);
+	free_contig_range(PHYS_PFN(pa), page_cnt);
+}
