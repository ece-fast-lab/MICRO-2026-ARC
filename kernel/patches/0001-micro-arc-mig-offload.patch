+#define AGI_PCIE_MMIO_ADDR      0x22feffa00000
+static void* get_device_va(void) {
+	void* virt_addr = ioremap(AGI_PCIE_MMIO_ADDR, 4096);
+	unsigned long long *ptr = (unsigned long long *) virt_addr;
+	return ptr;
+}
+static void clean_device_va(void* ptr) {
+    if (ptr != NULL) {
+        iounmap(ptr);
+    }
+}
+static int setup_mig_buffer(void) {
+    hppb_pair_buf_vaddr = NULL; 
+    hppb_src_buf_vaddr = NULL; 
+
+    pci_vaddr_ptr = get_device_va();
+
+    hppb_pair_buf_paddr = dst_buf.pa;
+    hppb_pair_buf_vaddr = dst_buf.va;
+    if (hppb_pair_buf_vaddr == (void *) -1 || hppb_pair_buf_vaddr == (void *) 0)
+        goto FAILED;
+
+    hppb_src_buf_paddr = src_buf.pa;
+    hppb_src_buf_vaddr = src_buf.va;
+    if (hppb_src_buf_vaddr == (void *) -1 || hppb_src_buf_vaddr == (void *) 0)
+        goto FAILED;
+
+    hppb_src_buf_vaddr[0] = 4294967295;      // Need MSB of 32-bit address to be 1
+    pci_vaddr_ptr[CSR_HPPB_PAIR_BUF_HEAD] = (hppb_pair_buf_paddr);
+    pci_vaddr_ptr[CSR_HPPB_SRC_BUF_HEAD] = (hppb_src_buf_paddr);
+
+    printk(KERN_INFO "Successful migration buffer setup.");
+    return 0;
+
+FAILED:
+    printk(KERN_ERR "ERROR in migration buffer setup!\n");
+	return -1;
+}
+/**
+ * ****************************
+ * FPGA trigger / work 
+ * ****************************
+*/
+static void fill_zero_pairs(const int pending) {
+	// perhaps optimize with filling only the necessray ones
+	int i;
+	for (i = pending; i < FPGA_MAX_COPY_GRANU; i++) {
+		hppb_pair_buf_vaddr[i * 2] = 0;
+		hppb_pair_buf_vaddr[(i * 2) + 1] = 0;
+	}
+}
+static uint64_t trigger_FPGA_copy(void) {
+	uint64_t ret = pci_vaddr_ptr[CSR_HPPB_COMPLETION_CNT];
+
+	fill_zero_pairs(offload_pending_sync);
+    pci_vaddr_ptr[CSR_HPPB_PAIR_VALID_COUNT]++;
+	total_cp_issued += offload_pending_sync;
+	offload_pending_sync = 0;
+
+	return ret;
+}
+static void fill_zero_pairs_async(void) {
+	int i;
+	for (i = offload_pending_async; i < FPGA_MAX_COPY_CNT; i++) {
+		hppb_pair_buf_vaddr[(i * 2)] = 0;
+		hppb_pair_buf_vaddr[(i * 2) + 1] = 1;
+	}
+}
+static void trigger_FPGA_copy_async(void) {
+	fill_zero_pairs_async();
+	total_cp_issued += offload_pending_async;
+	uint64_t orig_val = pci_vaddr_ptr[CSR_HPPB_PAIR_VALID_COUNT] & 0x0FFFFFFFFFFFFFFF;
+	uint64_t inc_val = (((offload_pending_async - 1) / fpga_copy_grnu) + 1);
+    pci_vaddr_ptr[CSR_HPPB_PAIR_VALID_COUNT] = orig_val + inc_val;
+
+}
+static void trigger_CPU_copy(void) {
+	int i;
+	struct folio *dst, *src;
+	for (i = 0; i < offload_pending_sync; i++) {
+		dst = pending_arr[i].dst;
+		src = pending_arr[i].src;
+		folio_mc_copy(dst, src);
+		//pr_info("i idx: %d\n", idx);
+	}
+	total_cp_issued += offload_pending_sync;
+	offload_pending_sync = 0;
+}
+static void trigger_CPU_copy_async(void) {
+	int i;
+	struct folio *dst, *src;
+	for (i = 0; i < (offload_pending_async % fpga_copy_grnu); i++) {
+		dst = pending_arr[i].dst;
+		src = pending_arr[i].src;
+		folio_mc_copy(dst, src);
+		pr_info("i : %d\n", i);
+	}
+	total_cp_issued += offload_pending_sync;
+	offload_pending_sync = 0;
+}
