+unsigned long cxl_pa_migrate(uint64_t *pfn_list, int cnt, int target_nid)
+{
+	unsigned long applied;
+	int i, enqueued, not_folio, not_lru;
+	LIST_HEAD(folio_list);
+	enqueued = 0;
+	not_folio = 0;
+	not_lru = 0;
+
+	for (i = 0; i < cnt; i++) {
+		struct folio *folio = damon_get_folio(PHYS_PFN(pfn_list[i]));
+
+		if (!folio) {
+			not_folio++;
+			//pr_info("not folio, dropping, 0x%lx\n", pfn_list[i]);
+			continue;
+		}
+
+		if (!folio_isolate_lru(folio)) {
+			not_lru++;
+			//pr_info("not LRU, dropping, 0x%lx\n", pfn_list[i]);
+			goto put_folio;
+		}
+
+		list_add(&folio->lru, &folio_list);
+		enqueued++;
+put_folio:
+		folio_put(folio);
+	}
+	//pr_info("cxl_pa_migrate: cnt: %d, enqueued: %d, not folio: %d, not lru: %d\n", cnt, enqueued, not_folio, not_lru);
+	// XXX
+	//if (enqueued < (cnt * 2 / 3)) return 0;
+	//pr_info("OK for %d pages\n", cnt);
+	applied = damon_pa_migrate_pages(&folio_list, target_nid, &cxl_target);
+	cond_resched();
+	return applied * PAGE_SIZE;
+}
+EXPORT_SYMBOL(cxl_pa_migrate);
 
