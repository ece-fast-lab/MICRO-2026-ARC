+static ssize_t proc_read_dst_pa(struct file *file, char __user *buffer, size_t buf_size, loff_t *offset) {
+    int len = sizeof(dst_buf.pa);
+    ssize_t ret = sizeof(dst_buf.pa);
+
+    pr_info("Trying to read from offset %lld.\n", *offset);
+    
+    /* Send physical address to user */
+    if (*offset >= len || copy_to_user(buffer, &dst_buf.pa, len)) {
+        pr_info("[ERROR] Copy to user failed.\n");
+        ret = 0;
+    } else {
+        pr_info("[INFO] Copy to user succeeded.\n");
+        *offset += len;
+    }
+
+    return ret; 
+}
