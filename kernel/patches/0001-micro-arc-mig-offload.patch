+static int proc_mmap_dst_buf(struct file *file, struct vm_area_struct *vma) {
+
+    int i = 0;
+    int ret;
+	unsigned long pfn;
+    unsigned long size = vma->vm_end - vma->vm_start;
+
+    /* Sanity check */
+    if (size != PAGE_SIZE * NUM_DST_ADDR_PAGE) {
+        pr_info("[ERROR] mmap va (0x%lx) not ok! Expect euqal to: (0x%lx)\n", 
+                size, PAGE_SIZE * NUM_DST_ADDR_PAGE);
+        return -ENOMEM;
+    }
+
+    pr_info("[DEBUG] dst mmap called. Page protection flag from vma struct is 0x%x\n", (uint32_t) vma->vm_page_prot.pgprot);
+
+    /* Map each page of the buffer to the given va range */
+	for (i = 0; i < 1; i++) {
+        pfn = dst_buf.pfn + i;
+		ret = remap_pfn_range(vma, vma->vm_start + i * PAGE_SIZE, pfn, PAGE_SIZE,  vma->vm_page_prot);
+		if (ret) {
+			pr_info("[ERROR] Error when map %lx to %lx. ret=%d\n",
+			 	vma->vm_start + i * PAGE_SIZE, pfn, ret);
+			return ret;
+		}
+	}
+	return 0;
+}
