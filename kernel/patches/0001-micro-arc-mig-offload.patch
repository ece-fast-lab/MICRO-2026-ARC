+static uint64_t spin_poll_fpga_copy_completion_target(uint64_t orig_val, uint64_t target_val) {
+    volatile uint64_t* pci_vaddr_ptr_vlt = pci_vaddr_ptr;
+	uint64_t curr_val = pci_vaddr_ptr_vlt[CSR_HPPB_COMPLETION_CNT];
+    // 2000 cycle
+    while (curr_val < target_val) {
+		curr_val = pci_vaddr_ptr_vlt[CSR_HPPB_COMPLETION_CNT];
+	}
+    return curr_val;
+}
+
+static uint64_t spin_poll_fpga_copy_completion(uint64_t orig_val) {
+    volatile uint64_t* pci_vaddr_ptr_vlt = pci_vaddr_ptr;
+	uint64_t curr_val = pci_vaddr_ptr_vlt[CSR_HPPB_COMPLETION_CNT];
+    // 2000 cycle
+    while (curr_val == orig_val) {
+		curr_val = pci_vaddr_ptr_vlt[CSR_HPPB_COMPLETION_CNT];
+	}
+    return curr_val;
+}
+
+// FPGA only
+void enqueue_offload_mig_async(struct folio* dst, struct folio* src) {
+	uint64_t src_pa;
+	uint64_t dst_pa;
+	struct page* page;
+
+	if (dst == NULL || src == NULL) {
+		trigger_FPGA_copy_async();
+	} else {
+		page = folio_page(src, 0);
+		src_pa = (uint64_t)page_to_phys(page);
+		page = folio_page(dst, 0);
+		dst_pa = (uint64_t)page_to_phys(page);
+
+		offload_status_arr[status_arr_marker].pending_block = pending_block_cnt;
+		hppb_pair_buf_vaddr[offload_pending_async * 2] = (uint32_t)((src_pa >> 12) & (0xFFFFFFFF));
+		hppb_pair_buf_vaddr[(offload_pending_async * 2) + 1] = (uint32_t)((dst_pa >> 12) & (0xFFFFFFFF));
+		pending_arr[offload_pending_async % FPGA_MAX_COPY_GRANU].src = src;
+		pending_arr[offload_pending_async % FPGA_MAX_COPY_GRANU].dst = dst;
+
+		offload_pending_async++;
+
+		// this should not happen in theory
+		if (offload_pending_async >= MAX_OFFLOAD_PENDING_IDX) {
+			pr_err("offload_pending_async reached max\n");
+			offload_pending_async = MAX_OFFLOAD_PENDING_IDX;
+		}
+
+		if (offload_pending_async % fpga_copy_grnu == 0) {
+			pending_block_cnt++;
+		}
+	}
+	//pr_info("[issue] p, v, o: %d, %d, %d\n", pending_block_cnt, val_csr_completion, offload_pending_async);
+}
+
+void enqueue_offload_mig(struct folio* dst, struct folio* src) {
+	uint64_t src_pa;
+	uint64_t dst_pa;
+	struct page* page;
+	if (dst == NULL || src == NULL) {
+		trigger_CPU_copy();
+	} else {
+		page = folio_page(src, 0);
+		src_pa = (uint64_t)page_to_phys(page);
+		page = folio_page(dst, 0);
+		dst_pa = (uint64_t)page_to_phys(page);
+
+		// set both cpu arr and FPGA arr
+		//	XXX opt for only one of them?
+		hppb_pair_buf_vaddr[offload_pending_sync * 2] = (uint32_t)((src_pa >> 12) & (0xFFFFFFFF));
+		hppb_pair_buf_vaddr[(offload_pending_sync * 2) + 1] = (uint32_t)((dst_pa >> 12) & (0xFFFFFFFF));
+		pending_arr[offload_pending_sync].src = src;
+		pending_arr[offload_pending_sync].dst = dst;
+		offload_pending_sync++;
+
+
+		// set status array
+		if (offload_mode == OFFLOAD_COPY_IMM_CPU) {
+			// trigger CPU to do immediate copy
+			trigger_CPU_copy();
+		} else if (offload_mode == OFFLOAD_COPY_IMM_FPGA) {
+			// trigger FPGA to do immediate copy
+            val_csr_completion = trigger_FPGA_copy();
+		} else {
+			if (offload_pending_sync == fpga_copy_grnu) {
+				if (offload_mode == OFFLOAD_COPY_BATCH_FPGA_SYNC) {
+					val_csr_completion = trigger_FPGA_copy();
+				} else {
+					// FIXME, no mode reachs here
+					trigger_CPU_copy();
+				}
+			}
+		}
+		if (offload_mode == OFFLOAD_COPY_BATCH_FPGA_SYNC || OFFLOAD_COPY_IMM_FPGA) {
+			spin_poll_fpga_copy_completion(val_csr_completion);
+		}
+	}
+	//pr_info("pending: %d\n", offload_pending_sync);
+}
+//
+// Module Manager
+//
+
+void reset_pending_cnt(void) {
+	pending_block_cnt = pci_vaddr_ptr[CSR_HPPB_COMPLETION_CNT];
+	val_csr_completion = pending_block_cnt; 
+	pending_block_base = pending_block_cnt;
+	pending_block_cnt++;
+	offload_pending_async = 0;
+}
+
+void check_offload_async_done(int pending_block) {
+	//pr_info("[postwork] p, v, pb: %d, %d, %d\n", pending_block_cnt, val_csr_completion, pending_block);
+	if (pending_block > pending_block_cnt) {
+		// impossible, all block is async is done by FPGA
+		pr_err("Check done bad, wrong pending_block: %d, cnt: %d\n", pending_block, pending_block_cnt);
+		return;
+	} else if (pending_block > val_csr_completion) {
+		cxl_set_t2();
+		val_csr_completion = spin_poll_fpga_copy_completion_target(val_csr_completion, pending_block);
+		cxl_accu_stat_t2(offload_postwork_check_spin_accu);
+		cxl_do_counting(offload_postwork_check_spin_cnt);
+	} else {
+		cxl_do_counting(offload_postwork_check_done_cnt);
+		// done
+		//pr_info("[postwork] block done: %d\n", pending_block);
+	}
+}
+
+int init_module_migrater(void)
+{
+	struct proc_dir_entry *file_ptr = NULL;
+	pending_block_cnt = 0;
+
+	offload_print_level = 0;
+	file_ptr = proc_create("offload_print_level", 0666, NULL, &print_level_file_ops);
+	if (!file_ptr) {
+		remove_proc_entry("offload_print_level", NULL);
+		return -ENOMEM;
+	}
+
+
+	// in include/linux/migrate_mode.h
+	cxl_migrate_mode = 0;
+	file_ptr = proc_create("cxl_migrate_mode", 0666, NULL, &mode_file_ops);
+	if (!file_ptr) {
+		remove_proc_entry("cxl_migrate_mode", NULL);
+		return -ENOMEM;
+	}
+
+	// in include/linux/cxl_migrate.h
+	offload_mode = 0;
+	file_ptr = proc_create("cxl_offload_mode", 0666, NULL, &offload_mode_file_ops);
+	if (!file_ptr) {
+		remove_proc_entry("cxl_offload_mode", NULL);
+		return -ENOMEM;
+	}
+
+	file_ptr = proc_create("hppb_src_addr_buf", 0444, NULL, &src_addr_buf_file_op);
+	if (!file_ptr) {
+		remove_proc_entry("hppb_src_addr_buf", NULL);
+		return -ENOMEM;
+	}
+
+    file_ptr = proc_create("hppb_dst_addr_buf", 0444, NULL, &dst_addr_buf_file_op);
+	if (!file_ptr) {
+		remove_proc_entry("hppb_dst_addr_buf", NULL);
+		return -ENOMEM;
+	}
+
+	file_ptr = proc_create("hppb_cxl_buf", 0444, NULL, &cxl_buf_file_op);
+	if (!file_ptr) {
+		remove_proc_entry("hppb_cxl_buf", NULL);
+		return -ENOMEM;
+	}
+
+	file_ptr = proc_create("hppb_host_buf", 0444, NULL, &host_buf_file_op);
+	if (!file_ptr) {
+		remove_proc_entry("hppb_host_buf", NULL);
+		return -ENOMEM;
+	}
+
+	file_ptr = proc_create("hppb_ctrl", 0666, NULL, &hppb_ctrl_file_op);
+	if (!file_ptr ) {
+		remove_proc_entry("hppb_ctrl", NULL);
+		return -ENOMEM;
+	}
+
+    if (!allocate_tracer_region(0, NUM_SRC_ADDR_PAGE, &src_buf.pa, &src_buf.va)) {
+        pr_err("Bad SRC ADDR alloc\n");
+		return -ENOMEM;
+    }
+    src_buf.pfn = PHYS_PFN(src_buf.pa);
+
+    if (!allocate_tracer_region(0, NUM_DST_ADDR_PAGE, &dst_buf.pa, &dst_buf.va)) {
+        pr_err("Bad DST ADDR alloc\n");
+		return -ENOMEM;
+    }
+    dst_buf.pfn = PHYS_PFN(dst_buf.pa);
+
+    if (!allocate_tracer_region(2, NUM_CXL_BUF_PAGE, &cxl_buf.pa, &cxl_buf.va)) {
+        pr_err("Bad cxl buf alloc\n");
+		return -ENOMEM;
+    }
+    cxl_buf.pfn = PHYS_PFN(cxl_buf.pa);
+
+    if (!allocate_tracer_region(0, NUM_HOST_BUF_PAGE, &host_buf.pa, &host_buf.va)) {
+        pr_err("Bad host buf alloc\n");
+		return -ENOMEM;
+    }
+    host_buf.pfn = PHYS_PFN(host_buf.pa);
+
+	if (!setup_mig_buffer()) {
+		pr_err("Bad setup device\n");
+		return -ENOMEM;	
+	}
+
+	memset(offload_status_arr, 0, sizeof(mig_pair_struct_t) * MAX_MIG_OFFLOAD_BATCH_SIZE);
+	memset(postwork_status_arr, 0, sizeof(u16) * MAX_MIG_OFFLOAD_BATCH_SIZE);
+	pr_info("done init cxl_migrate\n");
+	return 0;
+}
+
+void cleanup_module_migrater(void)
+{
+	remove_proc_entry("cxl_migrate_pfn", NULL);
+	remove_proc_entry("cxl_migrate_mode", NULL);
+    remove_proc_entry("hppb_src_addr_buf", NULL);
+    remove_proc_entry("hppb_dst_addr_buf", NULL);
+	remove_proc_entry("hppb_ctrl", NULL);
+    free_tracer_region(src_buf.pa, NUM_SRC_ADDR_PAGE);
+    free_tracer_region(dst_buf.pa, NUM_DST_ADDR_PAGE);
+    free_tracer_region(cxl_buf.pa, NUM_CXL_BUF_PAGE);
+    free_tracer_region(host_buf.pa, NUM_HOST_BUF_PAGE);
+	clean_device_va((void*)pci_vaddr_ptr);
+}
+
+
+late_initcall(init_module_migrater)
+module_exit(cleanup_module_migrater)
