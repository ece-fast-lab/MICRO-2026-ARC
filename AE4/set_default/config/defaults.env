#!/usr/bin/env bash

# System settings reproduced from the original SPR1 setup.
EXPECTED_HOSTNAME="${EXPECTED_HOSTNAME:-spr1}"
ALLOW_NON_SPR1="${ALLOW_NON_SPR1:-0}"
EXPECTED_KERNEL_RELEASE="${EXPECTED_KERNEL_RELEASE:-6.11.0-mig-offload+}"
EXPECTED_PCI_ID="${EXPECTED_PCI_ID:-8086:0ddb}"
REQUIRED_MEMMAP="${REQUIRED_MEMMAP:-124G\$0x180000000}"
BAR2_MIN_SIZE_BYTES="${BAR2_MIN_SIZE_BYTES:-2097152}"

CPU_FREQUENCY_KHZ="${CPU_FREQUENCY_KHZ:-2000000}"
UNCORE_RATIO_VALUE="${UNCORE_RATIO_VALUE:-0x1919}"
NUMA_BALANCING_MODE="${NUMA_BALANCING_MODE:-2}"
NUMA_DEMOTION_ENABLED="${NUMA_DEMOTION_ENABLED:-1}"
RESET_SWAP="${RESET_SWAP:-1}"
SWAP_RESET_HEADROOM_KB="${SWAP_RESET_HEADROOM_KB:-1048576}"

# The benchmark-time offset matches the GRUB memmap base and the original
# sw/set_para/chmu_offset_set.sh. It intentionally differs from the old setup
# helper that temporarily wrote zero to CSR 0x70.
CHMU_ADDRESS_OFFSET="${CHMU_ADDRESS_OFFSET:-0x180000000}"
CHMU_RANGE_LOWER="${CHMU_RANGE_LOWER:-0x0}"
CHMU_RANGE_UPPER="${CHMU_RANGE_UPPER:-0xFFFFFFFFFFFFF}"
CHMU_USER_BITS="${CHMU_USER_BITS:-0x2200000022}"
CHMU_QUERY_RATE="${CHMU_QUERY_RATE:-3000}"
CHMU_PUSH_RATE="${CHMU_PUSH_RATE:-2000}"

BUILD_THRESHOLDS=(16 32 64 96)
