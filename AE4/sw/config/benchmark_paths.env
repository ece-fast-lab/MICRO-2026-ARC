#!/usr/bin/env bash

# These workloads are intentionally not distributed with the artifact.
# Keep these as absolute paths on SPR1, or edit them for another machine.
SPEC_ROOT="${SPEC_ROOT:-/research/chihun/bench/spec2017}"
SPEC_RUNCPU="${SPEC_RUNCPU:-${SPEC_ROOT}/bin/runcpu}"
SPEC_CONFIG="${SPEC_CONFIG:-${SPEC_ROOT}/config/myprogram-gcc-linux-x86.cfg}"

GAPBS_ROOT="${GAPBS_ROOT:-/research/chihuns2/bench/gapbs/gapbs}"
GAPBS_GRAPH_DIR="${GAPBS_GRAPH_DIR:-${GAPBS_ROOT}/benchmark/graphs}"
GAPBS_WEB_GRAPH="${GAPBS_WEB_GRAPH:-}"
GAPBS_TWITTER_GRAPH="${GAPBS_TWITTER_GRAPH:-}"

# Optional: only required for the DAMON comparison mode.
DAMO_BIN="${DAMO_BIN:-}"
DAMO_CONFIG="${DAMO_CONFIG:-}"

# Real perf used by the original SPR1 adaptive runs. /usr/bin/perf is only an
# Ubuntu kernel-version dispatcher and does not work with 6.11.0-mig-offload+.
CHMU_PERF_BIN="${CHMU_PERF_BIN:-/research/chihuns2/kernel/linux-6.5.5/tools/perf/perf}"
